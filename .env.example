# ==============================================================================
# 统一环境变量配置
# 用法: cp .env.example .env，然后填入实际值
# ==============================================================================

# === PostgreSQL ===
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=changeme
DATABASE_SSL=false
POSTGRES_PORT=5432

# === Redis (BullMQ 队列) ===
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# === Meilisearch (产品搜索) ===
MEILI_MASTER_KEY=changeme_master_key_12345
MEILI_ENV=development
MEILI_PORT=7700

# === Strapi 后端 ===
NODE_ENV=production
BACKEND_PORT=1337

# Strapi 安全密钥（生产环境必须修改，生成命令: openssl rand -base64 32）
APP_KEYS=key1_change_me,key2_change_me,key3_change_me,key4_change_me
API_TOKEN_SALT=changeme_api_token_salt
ADMIN_JWT_SECRET=changeme_admin_jwt_secret
TRANSFER_TOKEN_SALT=changeme_transfer_token_salt
JWT_SECRET=changeme_jwt_secret

# 文件上传
UPLOAD_PROVIDER=local

# === Next.js 前端 ===
FRONTEND_PORT=3000
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 服务端 SSR 专用 URL（Docker 内部网络访问后端，不暴露给浏览器 bundle）
# 本地 dev 时留空即可，会回退到 NEXT_PUBLIC_STRAPI_API_URL
STRAPI_API_URL_SSR=http://backend:1337

# === Sentry (可选) ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === AI 客服（阿里云 DashScope / 通义千问）===
DASHSCOPE_API_KEY=
DASHSCOPE_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v2
AI_CHAT_SYSTEM_PROMPT=你是佑森小课堂的AI客服助手，负责回答家长关于幼小衔接课程、校区、预约等问题。请基于知识库内容回答，不确定时建议转人工客服。

# === 微信公众号（5C 集成，留空则相关功能不可用）===
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=

# === Nginx 反向代理（仅使用 docker-compose.nginx.yml 时生效）===
NGINX_PORT=80

# === Agent（多租户中央控制，A 块产物）===
# Central 管理后台的 WebSocket URL（central 部署在另一台服务器）
CENTRAL_WS_URL=wss://central.yousen.example.com/api/agent/ws
# Agent 长期 token（由 agent register 命令注册后自动写入，不要手动填）
AGENT_TOKEN=
# Agent 在 central 注册的服务器 ID（由 agent register 命令注册后自动写入）
SERVER_ID=
