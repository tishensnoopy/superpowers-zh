# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# PostgreSQL database connection settings
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=changeme
DATABASE_SSL=false

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# ==============================================================================
# STRAPI SECURITY KEYS
# ==============================================================================
# Generate these using: openssl rand -base64 32
APP_KEYS=key1_change_me,key2_change_me,key3_change_me,key4_change_me
API_TOKEN_SALT=changeme_api_token_salt
ADMIN_JWT_SECRET=changeme_admin_jwt_secret
TRANSFER_TOKEN_SALT=changeme_transfer_token_salt
JWT_SECRET=changeme_jwt_secret

# ==============================================================================
# REDIS CONFIGURATION (BullMQ Queue)
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ==============================================================================
# MEILISEARCH CONFIGURATION
# ==============================================================================
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=changeme_master_key_12345

# ==============================================================================
# ADMIN PANEL CONFIGURATION
# ==============================================================================
# Set to true to enable admin panel in production
ADMIN_ENABLED=true

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=info

# ==============================================================================
# CORS CONFIGURATION (R28)
# ==============================================================================
# Comma-separated browser origins allowed to call the API cross-origin.
# Leave EMPTY to reject all cross-origin browser requests (recommended when
# the Next.js frontend only talks to Strapi from its server side).
# Example: CORS_ORIGINS=https://yousen.tishensnoopy.cloud,https://www.yousen.tishensnoopy.cloud
CORS_ORIGINS=

# ==============================================================================
# FILE UPLOAD CONFIGURATION
# ==============================================================================
# Provider: local, aws-s3, cloudinary, etc.
UPLOAD_PROVIDER=local

# ==============================================================================
# WECHAT OFFICIAL ACCOUNT (公众号)
# ==============================================================================
# Leave placeholder values until real credentials are obtained
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TOKEN=your_webhook_verification_token

# ==============================================================================
# PROVISIONED INSTANCE EXTRAS (由 provision-new-customer.sh 生成)
# ==============================================================================
# 以下字段在母站 .env.example 中不存在，但由一键开通脚本写入新实例 .env：
# CUSTOMER_ID=          # 客户标识
# DOMAIN=               # 客户站点域名
# ENCRYPTION_KEY=       # Strapi 加密密钥（脚本随机生成）
# MEILISEARCH_API_KEY=  # MeiliSearch API 密钥（脚本随机生成）
# AI_API_KEY=           # Qwen API 密钥（留空，部署后手动配置）
# AI_MODEL=qwen-plus    # 默认模型
