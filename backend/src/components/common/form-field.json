{
  "kind": "component",
  "collectionName": "components_common_form_fields",
  "info": {
    "singularName": "form-field",
    "pluralName": "form-fields",
    "displayName": "Form Field",
    "description": "Contact form field",
    "icon": "FileText"
  },
  "attributes": {
    "label": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "字段显示标签（如 姓名 / 邮箱 / 留言）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "字段名（用于表单提交 key，如 name / email）"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "text",
        "email",
        "phone",
        "textarea",
        "select"
      ],
      "required": true,
      "description": "枚举值：text(单行文本) / email(邮箱) / phone(电话) / textarea(多行文本) / select(下拉选择)"
    },
    "required": {
      "type": "boolean",
      "default": false,
      "description": "是否为必填字段"
    },
    "placeholder": {
      "type": "string",
      "maxLength": 200,
      "description": "输入框占位提示文字",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "options": {
      "type": "json",
      "description": "下拉选项 JSON（仅 type=select 时使用，如 [\"选项1\",\"选项2\"]）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
