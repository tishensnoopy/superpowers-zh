{
  "kind": "component",
  "collectionName": "components_common_testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Customer testimonial",
    "icon": "MessageSquare"
  },
  "attributes": {
    "content": {
      "type": "text",
      "required": true,
      "description": "评价内容",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "author": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "评价人姓名",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "position": {
      "type": "string",
      "maxLength": 200,
      "description": "评价人头衔（如 学员家长 / 毕业学员）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "评价人所在公司/单位",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "评价人头像，建议尺寸 200x200，支持 JPG/PNG/WebP"
    }
  }
}
