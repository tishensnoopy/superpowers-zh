{
  "kind": "component",
  "collectionName": "components_common_social_links",
  "info": {
    "singularName": "social-link",
    "pluralName": "social-links",
    "displayName": "Social Link",
    "description": "Social media link item",
    "icon": "Link"
  },
  "attributes": {
    "platform": {
      "type": "enumeration",
      "enum": [
        "wechat",
        "weibo",
        "qq",
        "douyin",
        "linkedin",
        "twitter",
        "facebook",
        "instagram",
        "youtube"
      ],
      "required": true,
      "description": "Social media platform"
    },
    "url": {
      "type": "string",
      "required": false,
      "maxLength": 500,
      "description": "Social media profile URL (optional when QR image is used)",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "qrImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "description": "QR code image (e.g. WeChat official account)"
    },
    "label": {
      "type": "string",
      "maxLength": 100,
      "description": "Display label for the link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
