{
  "kind": "component",
  "collectionName": "components_common_social_links",
  "info": {
    "singularName": "social-link",
    "pluralName": "social-links",
    "displayName": "Social Link",
    "description": "Social media link item",
    "icon": "Link"
  },
  "attributes": {
    "platform": {
      "type": "enumeration",
      "enum": [
        "wechat",
        "weibo",
        "qq",
        "douyin",
        "linkedin",
        "twitter",
        "facebook",
        "instagram",
        "youtube"
      ],
      "required": true,
      "description": "枚举值：wechat(微信) / weibo(微博) / qq(QQ) / douyin(抖音) / linkedin(领英) / twitter(X) / facebook(Facebook) / instagram(Instagram) / youtube(YouTube)"
    },
    "url": {
      "type": "string",
      "required": false,
      "maxLength": 500,
      "description": "社交媒体主页 URL（使用二维码时可选填），绝对 URL（如 https://...）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "qrImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "description": "二维码图片（如微信公众号），建议尺寸 200x200，支持 JPG/PNG"
    },
    "label": {
      "type": "string",
      "maxLength": 100,
      "description": "链接显示文字（如 关注公众号）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
