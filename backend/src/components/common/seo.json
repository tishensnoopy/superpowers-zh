{
  "kind": "component",
  "collectionName": "components_common_seos",
  "info": {
    "singularName": "seo",
    "pluralName": "seos",
    "displayName": "SEO",
    "description": "SEO meta tags and structured data",
    "icon": "Search"
  },
  "attributes": {
    "metaTitle": {
      "type": "string",
      "maxLength": 60,
      "description": "SEO 标题（浏览器标签/搜索结果标题），建议 60 字以内",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "metaDescription": {
      "type": "string",
      "maxLength": 160,
      "description": "SEO 描述（搜索结果摘要），建议 160 字以内",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "metaKeywords": {
      "type": "string",
      "maxLength": 200,
      "description": "SEO 关键词，逗号分隔（对部分搜索引擎有效）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "canonicalUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "规范链接 URL（用于解决重复内容问题），绝对 URL（如 https://...）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "ogTitle": {
      "type": "string",
      "maxLength": 60,
      "description": "Open Graph 标题（分享到社交平台时显示）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "ogDescription": {
      "type": "string",
      "maxLength": 160,
      "description": "Open Graph 描述（分享到社交平台时显示）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Open Graph 分享图，建议尺寸 1200x630，支持 JPG/PNG/WebP"
    },
    "ogType": {
      "type": "enumeration",
      "enum": [
        "website",
        "article",
        "product"
      ],
      "default": "website",
      "description": "枚举值：website(网站) / article(文章) / product(产品)；Open Graph 类型"
    },
    "noindex": {
      "type": "boolean",
      "default": false,
      "description": "勾选后此页面不会被搜索引擎索引（适用于隐私政策/退费政策等页面）"
    }
  }
}
