{
  "kind": "component",
  "collectionName": "components_section_heroes",
  "info": {
    "singularName": "hero",
    "pluralName": "heroes",
    "displayName": "Hero",
    "description": "Hero section for homepage",
    "icon": "Layout"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "主标题（建议 ≤200 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "subtitle": {
      "type": "string",
      "description": "副标题（建议 ≤300 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "description": "描述文案，支持 Markdown 语法",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "backgroundImage": {
      "type": "media",
      "description": "Hero 区域背景大图，建议尺寸 1920x1080，支持 JPG/PNG/WebP",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "image1": {
      "type": "media",
      "description": "悬浮卡片图 1（左侧），建议尺寸 400x500，支持 PNG/WebP",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "image2": {
      "type": "media",
      "description": "悬浮卡片图 2（右侧），建议尺寸 400x500，支持 PNG/WebP",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "badgeText": {
      "type": "string",
      "description": "悬浮卡片上的徽标文字（如 优质教学）（建议 ≤100 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "badgeDesc": {
      "type": "string",
      "description": "徽标卡片第二行描述文字（如 连续5年优质教育机构）（建议 ≤100 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "stats": {
      "type": "component",
      "repeatable": true,
      "component": "common.stat",
      "description": "统计数字行（如 8年经验 / 6大校区）"
    },
    "buttonText": {
      "type": "string",
      "description": "按钮文字（建议 ≤50 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "buttonUrl": {
      "type": "string",
      "description": "按钮链接地址，相对路径（如 /courses）或绝对 URL（如 https://...）（建议 ≤500 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "button2Text": {
      "type": "string",
      "description": "第二个按钮文字（建议 ≤50 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "button2Url": {
      "type": "string",
      "description": "第二个按钮链接地址，相对路径或绝对 URL（建议 ≤500 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "isFullWidth": {
      "type": "boolean",
      "default": true,
      "description": "是否全宽展示"
    },
    "overlayColor": {
      "type": "string",
      "description": "遮罩样式，支持：'frosted' 毛玻璃 | 'transparent' 完全透明 | HEX 色值（如 #1C2B3A）| rgba 半透明（如 rgba(28,43,58,0.4)）；留空使用默认深蓝灰渐变（建议 ≤80 字符）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
