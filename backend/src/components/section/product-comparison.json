{
  "kind": "component",
  "collectionName": "components_section_product_comparisons",
  "info": {
    "singularName": "product-comparison",
    "pluralName": "product-comparisons",
    "displayName": "Product Comparison",
    "description": "Compare multiple products side by side",
    "icon": "GitCompare"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "区块标题",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "description": "对比产品列表（建议最多 4 个）"
    },
    "specs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-spec.product-spec",
      "description": "对比规格列表"
    }
  }
}
