{
  "kind": "component",
  "collectionName": "components_section_product_grids",
  "info": {
    "singularName": "product-grid",
    "pluralName": "product-grids",
    "displayName": "Product Grid",
    "description": "Display products in grid layout",
    "icon": "Grid"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "区块标题",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "description": "区块描述文案",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "description": "关联展示的产品列表"
    },
    "columns": {
      "type": "enumeration",
      "enum": [
        "2",
        "3",
        "4"
      ],
      "default": "3",
      "description": "枚举值：2(两列) / 3(三列) / 4(四列)；网格列数"
    },
    "showFilter": {
      "type": "boolean",
      "default": true,
      "description": "是否显示分类筛选器"
    },
    "categoryFilter": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-category.product-category",
      "description": "可筛选的分类列表"
    }
  }
}
