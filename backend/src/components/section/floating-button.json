{
  "kind": "component",
  "collectionName": "components_section_floating_buttons",
  "info": {
    "singularName": "floating-button",
    "pluralName": "floating-buttons",
    "displayName": "Floating Button",
    "description": "Floating action button for consultation",
    "icon": "Phone"
  },
  "attributes": {
    "icon": {
      "type": "string",
      "maxLength": 100,
      "description": "按钮图标名称（来自图标库，如 Phone / MessageCircle）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "label": {
      "type": "string",
      "maxLength": 50,
      "description": "按钮文字（如 立即咨询）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "action": {
      "type": "enumeration",
      "enum": [
        "contact",
        "chat",
        "phone",
        "callback"
      ],
      "default": "contact",
      "description": "枚举值：contact(跳转联系表单) / chat(打开 AI 对话) / phone(拨打电话) / callback(预约回拨)"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "电话号码（仅 action=phone 时使用）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "wechat": {
      "type": "string",
      "maxLength": 100,
      "description": "微信号（仅 action=chat 或 callback 时使用）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "position": {
      "type": "enumeration",
      "enum": [
        "bottom-right",
        "bottom-left"
      ],
      "default": "bottom-right",
      "description": "枚举值：bottom-right(右下角) / bottom-left(左下角)；按钮位置"
    }
  }
}
