{
  "kind": "component",
  "collectionName": "components_section_floating_buttons",
  "info": {
    "singularName": "floating-button",
    "pluralName": "floating-buttons",
    "displayName": "Floating Button",
    "description": "Floating action button for consultation",
    "icon": "Phone"
  },
  "attributes": {
    "icon": {
      "type": "string",
      "maxLength": 100,
      "description": "Button icon",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "label": {
      "type": "string",
      "maxLength": 50,
      "description": "Button text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "action": {
      "type": "enumeration",
      "enum": [
        "contact",
        "chat",
        "phone",
        "callback"
      ],
      "default": "contact",
      "description": "Action type"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "wechat": {
      "type": "string",
      "maxLength": 100,
      "description": "WeChat ID",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "position": {
      "type": "enumeration",
      "enum": [
        "bottom-right",
        "bottom-left"
      ],
      "default": "bottom-right",
      "description": "Button position"
    }
  }
}
