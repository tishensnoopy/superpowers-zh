{
  "kind": "collectionType",
  "collectionName": "teachers",
  "info": {
    "singularName": "teacher",
    "pluralName": "teachers",
    "displayName": "教师",
    "description": "教师信息"
  },
  "options": {
    "draftAndPublish": true,
    "singleton": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "教师姓名",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "description": "URL 路径（由姓名自动生成）"
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "职称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "description": "教师头像，建议尺寸 400x400，支持 JPG/PNG/WebP"
    },
    "campus": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::campus.campus",
      "inversedBy": "teachers",
      "description": "所属校区（旧 manyToOne，迁移完成后将删除）"
    },
    "campus_links": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::campus-teacher-link.campus-teacher-link",
      "mappedBy": "teacher",
      "description": "教师↔校区多对多关联（经中间表，支持 status 软删除）"
    },
    "product_links": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::teacher-product-link.teacher-product-link",
      "mappedBy": "teacher",
      "description": "教师↔课程多对多关联（经中间表）"
    },
    "subject": {
      "type": "enumeration",
      "enum": [
        "pinyin",
        "math",
        "english",
        "comprehensive"
      ],
      "description": "枚举值：pinyin(拼音) / math(数学) / english(英语) / comprehensive(综合)"
    },
    "teachingYears": {
      "type": "integer",
      "default": 0,
      "description": "教龄，单位 年"
    },
    "education": {
      "type": "text",
      "description": "教育背景",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "teachingFeatures": {
      "type": "text",
      "description": "教学特色",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "achievements": {
      "type": "json",
      "description": "荣誉成就（字符串数组）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "description": "是否为特色教师"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "description": "排序"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "aiSummary": {
      "type": "text",
      "description": "GEO：给 AI 搜索引擎看的教师摘要（留空则自动从 title/achievements 生成）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
