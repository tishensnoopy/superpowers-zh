{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "页面",
    "description": "动态页面，支持拖拽区块组装",
    "icon": "FileText",
    "draftAndPublish": true
  },
  "options": {
    "draftAndPublish": true,
    "singleton": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "页面标题",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 200,
      "description": "页面 URL 路径"
    },
    "isHomepage": {
      "type": "boolean",
      "default": false,
      "description": "是否为首页"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "section.hero",
        "section.advantages",
        "section.rich-text",
        "section.product-grid",
        "section.product-comparison",
        "section.features",
        "section.team",
        "section.testimonials",
        "section.contact-form",
        "section.faq",
        "section.gallery",
        "section.floating-button"
      ],
      "description": "页面区块（拖拽排序）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::page.page",
      "inversedBy": "children",
      "description": "父页面"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "parent",
      "description": "子页面"
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "full-width",
        "boxed",
        "sidebar-left",
        "sidebar-right"
      ],
      "default": "full-width",
      "description": "枚举值：full-width(全宽) / boxed(盒装) / sidebar-left(左侧栏) / sidebar-right(右侧栏)"
    },
    "showNavigation": {
      "type": "boolean",
      "default": true,
      "description": "显示导航栏"
    },
    "showFooter": {
      "type": "boolean",
      "default": true,
      "description": "显示页脚"
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
