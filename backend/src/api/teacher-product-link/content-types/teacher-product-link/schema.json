{
  "kind": "collectionType",
  "collectionName": "teacher_product_links",
  "info": {
    "singularName": "teacher-product-link",
    "pluralName": "teacher-product-links",
    "displayName": "教师课程关联",
    "description": "教师↔课程(product)多对多关系中间表（显式，支持 status 软删除）",
    "icon": "Link"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "teacher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::teacher.teacher",
      "inversedBy": "product_links",
      "description": "关联教师"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "teacher_links",
      "description": "关联课程(product)"
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive"],
      "default": "active",
      "required": true,
      "description": "关系状态：active=当前有效，inactive=历史归档"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "description": "排序"
    },
    "notes": {
      "type": "text",
      "description": "关系备注（如主讲、助教等）"
    }
  }
}
