{
  "kind": "collectionType",
  "collectionName": "navigations",
  "info": {
    "singularName": "navigation",
    "pluralName": "navigations",
    "displayName": "Navigation",
    "description": "Site navigation menu items",
    "icon": "Menu",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "导航项显示名称（如 关于我们 / 课程体系）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "url": {
      "type": "string",
      "required": true,
      "maxLength": 500,
      "description": "链接地址，相对路径（如 /about）或绝对 URL（如 https://...）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "icon": {
      "type": "string",
      "maxLength": 100,
      "description": "图标名称（来自图标库，如 Home / Users）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "position": {
      "type": "integer",
      "default": 0,
      "description": "排序权重，数值越小越靠前"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "是否启用此导航项"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::navigation.navigation",
      "mappedBy": "parent",
      "description": "子导航项（下拉菜单）"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::navigation.navigation",
      "inversedBy": "children",
      "description": "父级导航项"
    },
    "isExternal": {
      "type": "boolean",
      "default": false,
      "description": "是否为外部链接（true 时新窗口打开）"
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
