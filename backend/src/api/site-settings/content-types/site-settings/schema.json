{
  "kind": "collectionType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-settings",
    "pluralName": "site-settings-global",
    "displayName": "站点设置",
    "description": "全局站点设置和配置",
    "icon": "Settings",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255,
      "minLength": 1,
      "description": "站点名称 / 品牌名称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slogan": {
      "type": "string",
      "maxLength": 500,
      "description": "站点标语",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "logo": {
      "type": "media",
      "description": "站点 Logo 图片",
      "multiple": false
    },
    "favicon": {
      "type": "media",
      "description": "网站图标",
      "multiple": false
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "联系电话",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "email": {
      "type": "string",
      "maxLength": 255,
      "description": "联系邮箱",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "address": {
      "type": "text",
      "description": "公司地址",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "wechat": {
      "type": "string",
      "maxLength": 100,
      "description": "微信号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "icp": {
      "type": "string",
      "maxLength": 100,
      "description": "ICP 备案号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "publicSecurityRecord": {
      "type": "string",
      "maxLength": 100,
      "description": "公安备案号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "primaryColor": {
      "type": "string",
      "maxLength": 20,
      "description": "品牌主色：填入 6 位十六进制色值（如 #F5851F），留空使用默认橙色。修改后全站按钮/链接/强调色实时生效"
    },
    "darkColor": {
      "type": "string",
      "maxLength": 20,
      "description": "品牌深色：填入 6 位十六进制色值（如 #1C2B3A），留空使用默认深蓝灰。修改后全站深色背景/标题文字实时生效"
    },
    "fontSettings": {
      "type": "component",
      "component": "common.font-settings",
      "description": "字体设置：字体族 + 字体文件，留空用默认字体"
    },
    "aiSummary": {
      "type": "text",
      "description": "GEO：给 AI 搜索引擎看的机构摘要（写入 llms.txt）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "googleVerification": {
      "type": "string",
      "maxLength": 200,
      "description": "Google Search Console 验证码（如 google-site-verification=xxx）"
    },
    "bingVerification": {
      "type": "string",
      "maxLength": 200,
      "description": "Bing Webmaster 验证码（如 msvalidate.01=xxx）"
    },
    "baiduVerification": {
      "type": "string",
      "maxLength": 200,
      "description": "百度站长平台验证码（如 baidu-site-verification=xxx）"
    },
    "analytics": {
      "type": "component",
      "component": "common.analytics",
      "description": "第三方统计代码配置（GA4 / 百度统计 / Facebook Pixel）"
    },
    "defaultOgImage": {
      "type": "media",
      "multiple": false,
      "description": "站点级默认分享图（页面未配置 OG 图时回退到此图）"
    }
  },
  "admin": {
    "list": {
      "title": "站点设置",
      "description": "管理全局站点配置",
      "fields": [
        {
          "field": "name",
          "label": "站点名称"
        },
        {
          "field": "phone",
          "label": "联系电话"
        },
        {
          "field": "email",
          "label": "联系邮箱"
        }
      ]
    },
    "edit": {
      "title": "编辑站点设置",
      "description": "修改全局站点配置",
      "fields": [
        {
          "field": "name",
          "label": "站点名称",
          "placeholder": "请输入站点名称"
        },
        {
          "field": "slogan",
          "label": "站点标语",
          "placeholder": "请输入站点标语"
        },
        {
          "field": "logo",
          "label": "站点 Logo"
        },
        {
          "field": "favicon",
          "label": "网站图标"
        },
        {
          "field": "phone",
          "label": "联系电话",
          "placeholder": "请输入联系电话"
        },
        {
          "field": "email",
          "label": "联系邮箱",
          "placeholder": "请输入联系邮箱"
        },
        {
          "field": "address",
          "label": "公司地址",
          "placeholder": "请输入公司地址"
        },
        {
          "field": "wechat",
          "label": "微信号",
          "placeholder": "请输入微信号"
        },
        {
          "field": "icp",
          "label": "ICP 备案号",
          "placeholder": "请输入 ICP 备案号"
        },
        {
          "field": "publicSecurityRecord",
          "label": "公安备案号",
          "placeholder": "请输入公安备案号"
        },
        {
          "field": "seo",
          "label": "SEO 配置"
        },
        {
          "field": "primaryColor",
          "label": "品牌主色",
          "placeholder": "#F5851F"
        },
        {
          "field": "darkColor",
          "label": "深色（标题/背景）",
          "placeholder": "#1C2B3A"
        },
        {
          "field": "fontSettings",
          "label": "字体设置"
        },
        {
          "field": "aiSummary",
          "label": "AI 摘要（GEO）",
          "placeholder": "写给 AI 搜索引擎看的机构简介，将写入 llms.txt"
        },
        {
          "field": "googleVerification",
          "label": "Google 验证码",
          "placeholder": "google-site-verification=xxx"
        },
        {
          "field": "bingVerification",
          "label": "Bing 验证码",
          "placeholder": "msvalidate.01=xxx"
        },
        {
          "field": "baiduVerification",
          "label": "百度验证码",
          "placeholder": "baidu-site-verification=xxx"
        },
        {
          "field": "analytics",
          "label": "统计代码"
        },
        {
          "field": "defaultOgImage",
          "label": "默认分享图"
        }
      ]
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
