{
  "kind": "collectionType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-settings",
    "pluralName": "site-settings-global",
    "displayName": "站点设置",
    "description": "全局站点设置和配置",
    "icon": "Settings",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255,
      "minLength": 1,
      "description": "站点名称 / 品牌名称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slogan": {
      "type": "string",
      "maxLength": 500,
      "description": "站点标语",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "logo": {
      "type": "media",
      "description": "站点 Logo 图片",
      "multiple": false
    },
    "favicon": {
      "type": "media",
      "description": "网站图标",
      "multiple": false
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "联系电话",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "email": {
      "type": "string",
      "maxLength": 255,
      "description": "联系邮箱",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "address": {
      "type": "text",
      "description": "公司地址",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "wechat": {
      "type": "string",
      "maxLength": 100,
      "description": "微信号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "icp": {
      "type": "string",
      "maxLength": 100,
      "description": "ICP 备案号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "publicSecurityRecord": {
      "type": "string",
      "maxLength": 100,
      "description": "公安备案号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "admin": {
    "list": {
      "title": "站点设置",
      "description": "管理全局站点配置",
      "fields": [
        {
          "field": "name",
          "label": "站点名称"
        },
        {
          "field": "phone",
          "label": "联系电话"
        },
        {
          "field": "email",
          "label": "联系邮箱"
        }
      ]
    },
    "edit": {
      "title": "编辑站点设置",
      "description": "修改全局站点配置",
      "fields": [
        {
          "field": "name",
          "label": "站点名称",
          "placeholder": "请输入站点名称"
        },
        {
          "field": "slogan",
          "label": "站点标语",
          "placeholder": "请输入站点标语"
        },
        {
          "field": "logo",
          "label": "站点 Logo"
        },
        {
          "field": "favicon",
          "label": "网站图标"
        },
        {
          "field": "phone",
          "label": "联系电话",
          "placeholder": "请输入联系电话"
        },
        {
          "field": "email",
          "label": "联系邮箱",
          "placeholder": "请输入联系邮箱"
        },
        {
          "field": "address",
          "label": "公司地址",
          "placeholder": "请输入公司地址"
        },
        {
          "field": "wechat",
          "label": "微信号",
          "placeholder": "请输入微信号"
        },
        {
          "field": "icp",
          "label": "ICP 备案号",
          "placeholder": "请输入 ICP 备案号"
        },
        {
          "field": "publicSecurityRecord",
          "label": "公安备案号",
          "placeholder": "请输入公安备案号"
        },
        {
          "field": "seo",
          "label": "SEO 配置"
        }
      ]
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
