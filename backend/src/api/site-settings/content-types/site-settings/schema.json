{
  "kind": "collectionType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-settings",
    "pluralName": "site-settings-global",
    "displayName": "站点设置",
    "description": "全局站点设置和配置",
    "icon": "Settings",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255,
      "minLength": 1,
      "description": "站点名称 / 品牌名称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slogan": {
      "type": "string",
      "maxLength": 500,
      "description": "站点标语",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "logo": {
      "type": "media",
      "description": "站点 Logo 图片，建议尺寸 200x200，支持 SVG/PNG/WebP",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "description": "网站图标 favicon，建议尺寸 32x32 或 64x64，支持 ICO/PNG/SVG",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "联系电话",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "showPhoneInNav": {
      "type": "boolean",
      "default": true,
      "description": "是否在导航栏显示电话号码，关闭后导航栏将不显示电话组件"
    },
    "email": {
      "type": "string",
      "maxLength": 255,
      "description": "联系邮箱",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "address": {
      "type": "text",
      "description": "公司地址",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "wechat": {
      "type": "string",
      "maxLength": 100,
      "description": "微信号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "icp": {
      "type": "string",
      "maxLength": 100,
      "description": "ICP 备案号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "icpUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "ICP 备案号点击跳转链接，默认指向工信部备案查询网址 https://beian.miit.gov.cn/"
    },
    "publicSecurityRecord": {
      "type": "string",
      "maxLength": 100,
      "description": "公安备案号",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "publicSecurityRecordUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "公安备案号点击跳转链接，默认指向全国互联网安全管理平台 http://www.beian.gov.cn/"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "primaryColor": {
      "type": "string",
      "maxLength": 20,
      "description": "品牌主色：填入 6 位十六进制色值（如 #F5851F），留空使用默认橙色。修改后全站按钮/链接/强调色实时生效"
    },
    "darkColor": {
      "type": "string",
      "maxLength": 20,
      "description": "品牌深色：填入 6 位十六进制色值（如 #1C2B3A），留空使用默认深蓝灰。修改后全站深色背景/标题文字实时生效"
    },
    "fontSettings": {
      "type": "component",
      "component": "common.font-settings",
      "description": "字体设置：字体族 + 字体文件，留空用默认字体"
    },
    "aiSummary": {
      "type": "text",
      "description": "GEO：给 AI 搜索引擎看的机构摘要（写入 llms.txt）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "googleVerification": {
      "type": "string",
      "maxLength": 200,
      "description": "Google Search Console 验证码（如 google-site-verification=xxx）"
    },
    "bingVerification": {
      "type": "string",
      "maxLength": 200,
      "description": "Bing Webmaster 验证码（如 msvalidate.01=xxx）"
    },
    "baiduVerification": {
      "type": "string",
      "maxLength": 200,
      "description": "百度站长平台验证码（如 baidu-site-verification=xxx）"
    },
    "analytics": {
      "type": "component",
      "component": "common.analytics",
      "description": "第三方统计代码配置（GA4 / 百度统计 / Facebook Pixel）"
    },
    "defaultOgImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "站点级默认分享图，建议尺寸 1200x630，支持 JPG/PNG/WebP（页面未配置 OG 图时回退到此图）"
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
