{
  "kind": "collectionType",
  "collectionName": "news_articles",
  "info": {
    "singularName": "news-article",
    "pluralName": "news-articles",
    "displayName": "新闻文章",
    "description": "新闻动态文章"
  },
  "options": {
    "draftAndPublish": true,
    "singleton": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "文章标题",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "URL 路径（由标题自动生成）"
    },
    "excerpt": {
      "type": "text",
      "maxLength": 500,
      "description": "文章摘要（列表页展示）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "richtext",
      "description": "文章正文，支持 Markdown 语法（详情页展示）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "description": "封面图，建议尺寸 1200x630，支持 JPG/PNG/WebP"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "company_news",
        "industry_news",
        "event_notice"
      ],
      "default": "company_news",
      "description": "枚举值：company_news(公司新闻) / industry_news(行业动态) / event_notice(活动公告)"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "description": "是否为头条新闻"
    },
    "viewCount": {
      "type": "integer",
      "default": 0,
      "description": "阅读量"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "description": "排序"
    },
    "tags": {
      "type": "string",
      "description": "逗号分隔的标签",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "aiSummary": {
      "type": "text",
      "description": "GEO：给 AI 搜索引擎看的新闻摘要（留空则自动从 excerpt 生成）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
