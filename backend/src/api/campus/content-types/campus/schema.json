{
  "kind": "collectionType",
  "collectionName": "campuses",
  "info": {
    "singularName": "campus",
    "pluralName": "campuses",
    "displayName": "校区",
    "description": "校区信息",
    "icon": "MapPin"
  },
  "options": {
    "draftAndPublish": true,
    "singleton": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "校区名称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "description": "URL 路径"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "description": "校区封面图"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ],
      "description": "校区环境图集"
    },
    "address": {
      "type": "string",
      "required": true,
      "maxLength": 500,
      "description": "校区地址",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "联系电话",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "contactPerson": {
      "type": "string",
      "maxLength": 100,
      "description": "联系人",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "businessHours": {
      "type": "string",
      "maxLength": 200,
      "description": "营业时间",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "transportation": {
      "type": "text",
      "description": "交通信息",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "area": {
      "type": "string",
      "maxLength": 100,
      "description": "教学面积",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "description": "校区简介",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "latitude": {
      "type": "float",
      "description": "纬度（GCJ-02 火星坐标系）"
    },
    "longitude": {
      "type": "float",
      "description": "经度（GCJ-02 火星坐标系）"
    },
    "mapEmbed": {
      "type": "text",
      "description": "地图嵌入代码（已废弃，保留兼容）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "description": "排序"
    },
    "teachers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::teacher.teacher",
      "mappedBy": "campus",
      "description": "校区教师"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
