{
  "kind": "collectionType",
  "collectionName": "knowledge_bases",
  "info": {
    "singularName": "knowledge-base",
    "pluralName": "knowledge-bases",
    "displayName": "Knowledge Base",
    "description": "Knowledge base document with vectorization support",
    "icon": "Book",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "Document title"
    },
    "content": {
      "type": "text",
      "description": "Document content"
    },
    "sourceType": {
      "type": "enumeration",
      "enum": [
        "manual",
        "faq",
        "pdf",
        "webpage",
        "chat-history",
        "content-sync"
      ],
      "default": "manual",
      "description": "Source type"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "ready",
        "failed"
      ],
      "default": "pending",
      "description": "Processing status"
    },
    "vectorizationStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "default": "pending",
      "description": "向量化状态"
    },
    "statusMessage": {
      "type": "string",
      "maxLength": 500,
      "description": "Status message (error reason, etc.)"
    },
    "vectorDbIds": {
      "type": "json",
      "description": "Vector database IDs (array)"
    },
    "chunkCount": {
      "type": "integer",
      "default": 0,
      "description": "Number of document chunks"
    },
    "processedAt": {
      "type": "datetime",
      "description": "Processing completed timestamp"
    },
    "failedAt": {
      "type": "datetime",
      "description": "Failed timestamp"
    },
    "retryCount": {
      "type": "integer",
      "default": 0,
      "description": "Number of retries"
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium",
      "description": "Processing priority"
    },
    "tags": {
      "type": "string",
      "maxLength": 500,
      "description": "Tags (comma separated)"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO configuration"
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq-item.faq-item",
      "mappedBy": "sourceDocument",
      "description": "FAQs generated from this document"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files",
        "images"
      ],
      "description": "Uploaded document file"
    },
    "sourceUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "Source URL for webpage type"
    },
    "category": {
      "type": "string",
      "maxLength": 100,
      "description": "Document category"
    }
  }
}
