{
  "kind": "collectionType",
  "collectionName": "knowledge_bases",
  "info": {
    "singularName": "knowledge-base",
    "pluralName": "knowledge-bases",
    "displayName": "Knowledge Base",
    "description": "Knowledge base document with vectorization support",
    "icon": "Book",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "文档标题",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "text",
      "description": "文档正文内容，支持 Markdown 语法",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sourceType": {
      "type": "enumeration",
      "enum": [
        "manual",
        "faq",
        "pdf",
        "webpage",
        "chat-history",
        "content-sync"
      ],
      "default": "manual",
      "description": "枚举值：manual(人工录入) / faq(FAQ 同步) / pdf(PDF 上传) / webpage(网页抓取) / chat-history(对话历史) / content-sync(内容同步)"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "ready",
        "failed"
      ],
      "default": "pending",
      "description": "枚举值：pending(待处理) / processing(处理中) / ready(就绪) / failed(失败)"
    },
    "vectorizationStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "default": "pending",
      "description": "枚举值：pending(待向量化) / processing(向量化中) / completed(已完成) / failed(失败)"
    },
    "statusMessage": {
      "type": "string",
      "maxLength": 500,
      "description": "状态说明信息（如错误原因）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "vectorDbIds": {
      "type": "json",
      "description": "向量数据库记录 ID 数组",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "chunkCount": {
      "type": "integer",
      "default": 0,
      "description": "文档分块数量，单位 个"
    },
    "processedAt": {
      "type": "datetime",
      "description": "处理完成时间"
    },
    "failedAt": {
      "type": "datetime",
      "description": "处理失败时间"
    },
    "retryCount": {
      "type": "integer",
      "default": 0,
      "description": "重试次数，单位 次"
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium",
      "description": "枚举值：low(低) / medium(中) / high(高)；处理优先级"
    },
    "tags": {
      "type": "string",
      "maxLength": 500,
      "description": "标签，逗号分隔",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq-item.faq-item",
      "mappedBy": "sourceDocument",
      "description": "从本文档生成的 FAQ 列表"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files",
        "images"
      ],
      "description": "上传的文档文件，支持 PDF/Word/TXT/Markdown"
    },
    "sourceUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "来源网页 URL（仅 sourceType=webpage 时使用）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "type": "string",
      "maxLength": 100,
      "description": "文档分类",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
