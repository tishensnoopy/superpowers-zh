{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "产品",
    "description": "产品目录项",
    "icon": "Package",
    "draftAndPublish": true
  },
  "options": {
    "draftAndPublish": true,
    "singleton": false
  },
  "lifecycle": {
    "afterCreate": "./lifecycles",
    "afterUpdate": "./lifecycles",
    "afterDelete": "./lifecycles"
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "产品名称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 200,
      "description": "产品 URL 路径"
    },
    "description": {
      "type": "text",
      "description": "产品描述",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 500,
      "description": "列表显示的简短描述",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "price": {
      "type": "float",
      "description": "售价，单位 元"
    },
    "originalPrice": {
      "type": "float",
      "description": "原价，单位 元（用于显示折扣）"
    },
    "sku": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100,
      "description": "SKU 编码"
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "description": "库存数量"
    },
    "isInStock": {
      "type": "boolean",
      "default": true,
      "description": "是否有库存"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "description": "是否为特色产品"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "description": "产品图片，建议尺寸 1200x1200，支持 JPG/PNG/WebP"
    },
    "thumbnail": {
      "type": "media",
      "description": "产品缩略图，建议尺寸 400x400，支持 JPG/PNG/WebP",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-category.product-category",
      "inversedBy": "products",
      "description": "产品分类"
    },
    "specs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-spec.product-spec",
      "description": "产品规格"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "aiSummary": {
      "type": "text",
      "description": "GEO：给 AI 搜索引擎看的课程摘要（留空则自动从 description 生成）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "specValues": {
      "type": "json",
      "description": "规格值（键值对）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "teachingMethod": {
      "type": "richtext",
      "description": "教学方法描述，支持 Markdown 语法",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "objectives": {
      "type": "component",
      "component": "course.objective",
      "repeatable": true,
      "description": "学习目标列表",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "outline": {
      "type": "component",
      "component": "course.module",
      "repeatable": true,
      "description": "课程大纲分阶段",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "testimonials": {
      "type": "component",
      "component": "course.testimonial",
      "repeatable": true,
      "description": "家长评价",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
