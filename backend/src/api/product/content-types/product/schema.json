{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "产品",
    "description": "产品目录项",
    "icon": "Package",
    "draftAndPublish": true
  },
  "options": {
    "draftAndPublish": true,
    "singleton": false
  },
  "lifecycle": {
    "afterCreate": "./lifecycles",
    "afterUpdate": "./lifecycles",
    "afterDelete": "./lifecycles"
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "description": "产品名称"
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 200,
      "description": "产品 URL 路径"
    },
    "description": {
      "type": "text",
      "description": "产品描述"
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 500,
      "description": "列表显示的简短描述"
    },
    "price": {
      "type": "float",
      "description": "价格"
    },
    "originalPrice": {
      "type": "float",
      "description": "原价（用于显示折扣）"
    },
    "sku": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100,
      "description": "SKU 编码"
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "description": "库存数量"
    },
    "isInStock": {
      "type": "boolean",
      "default": true,
      "description": "是否有库存"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "description": "是否为特色产品"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "description": "产品图片"
    },
    "thumbnail": {
      "type": "media",
      "description": "产品缩略图",
      "multiple": false
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-category.product-category",
      "inversedBy": "products",
      "description": "产品分类"
    },
    "specs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-spec.product-spec",
      "description": "产品规格"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "description": "SEO 配置"
    },
    "specValues": {
      "type": "json",
      "description": "规格值（键值对）"
    },
    "teachingMethod": {
      "type": "richtext",
      "description": "教学方法描述"
    },
    "objectives": {
      "type": "component",
      "component": "course.objective",
      "repeatable": true,
      "description": "学习目标列表"
    },
    "outline": {
      "type": "component",
      "component": "course.module",
      "repeatable": true,
      "description": "课程大纲分阶段"
    },
    "testimonials": {
      "type": "component",
      "component": "course.testimonial",
      "repeatable": true,
      "description": "家长评价"
    }
  },
  "admin": {
    "list": {
      "title": "产品管理",
      "description": "管理产品目录",
      "fields": [
        {
          "field": "name",
          "label": "产品名称",
          "sortable": true
        },
        {
          "field": "slug",
          "label": "URL 路径",
          "sortable": true
        },
        {
          "field": "price",
          "label": "价格",
          "sortable": true
        },
        {
          "field": "isFeatured",
          "label": "特色",
          "sortable": true
        },
        {
          "field": "isInStock",
          "label": "库存",
          "sortable": true
        },
        {
          "field": "publishedAt",
          "label": "发布时间",
          "sortable": true
        }
      ],
      "filters": [
        {
          "field": "categories",
          "label": "分类"
        },
        {
          "field": "isFeatured",
          "label": "特色产品"
        },
        {
          "field": "isInStock",
          "label": "库存状态"
        },
        {
          "field": "publishedAt",
          "label": "发布状态"
        }
      ]
    },
    "edit": {
      "title": "编辑产品",
      "description": "创建或编辑产品",
      "fields": [
        {
          "field": "name",
          "label": "产品名称",
          "placeholder": "请输入产品名称"
        },
        {
          "field": "slug",
          "label": "URL 路径",
          "placeholder": "请输入产品路径"
        },
        {
          "field": "sku",
          "label": "SKU 编码",
          "placeholder": "请输入 SKU 编码"
        },
        {
          "field": "price",
          "label": "价格"
        },
        {
          "field": "originalPrice",
          "label": "原价"
        },
        {
          "field": "stock",
          "label": "库存数量"
        },
        {
          "field": "isInStock",
          "label": "有库存"
        },
        {
          "field": "isFeatured",
          "label": "设为特色产品"
        },
        {
          "field": "shortDescription",
          "label": "简短描述",
          "placeholder": "请输入简短描述"
        },
        {
          "field": "description",
          "label": "详细描述"
        },
        {
          "field": "images",
          "label": "产品图片"
        },
        {
          "field": "thumbnail",
          "label": "缩略图"
        },
        {
          "field": "categories",
          "label": "产品分类"
        },
        {
          "field": "specs",
          "label": "产品规格"
        },
        {
          "field": "seo",
          "label": "SEO 配置"
        },
        {
          "field": "teachingMethod",
          "label": "教学方法",
          "placeholder": "请输入教学方法描述"
        },
        {
          "field": "objectives",
          "label": "学习目标"
        },
        {
          "field": "outline",
          "label": "课程大纲"
        },
        {
          "field": "testimonials",
          "label": "家长评价"
        }
      ]
    }
  }
}
