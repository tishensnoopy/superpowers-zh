{
  "kind": "collectionType",
  "collectionName": "faq_items",
  "info": {
    "singularName": "faq-item",
    "pluralName": "faq-items",
    "displayName": "FAQ Item",
    "description": "Frequently asked question",
    "icon": "HelpCircle",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": false
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true,
      "maxLength": 500,
      "description": "FAQ 问题文本",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "answer": {
      "type": "text",
      "required": true,
      "description": "FAQ 答案，支持 Markdown 语法",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "type": "string",
      "maxLength": 100,
      "description": "FAQ 分类名称（如 入学咨询 / 课程 / 收费）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "tags": {
      "type": "string",
      "maxLength": 500,
      "description": "标签，逗号分隔（如 拼音,数学,试听）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "是否在前台展示"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "description": "排序权重，数值越小越靠前"
    },
    "sourceDocument": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::knowledge-base.knowledge-base",
      "inversedBy": "faqs",
      "description": "来源知识库文档"
    },
    "feedbackCount": {
      "type": "integer",
      "default": 0,
      "description": "用户反馈总数"
    },
    "helpfulCount": {
      "type": "integer",
      "default": 0,
      "description": "认为有用的人数"
    },
    "sourceType": {
      "type": "enumeration",
      "enum": [
        "manual",
        "ai-generated",
        "chat-feedback"
      ],
      "default": "manual",
      "description": "枚举值：manual(人工录入) / ai-generated(AI 生成) / chat-feedback(对话反馈提炼)"
    },
    "sourceSession": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::chat-session.chat-session",
      "description": "AI 生成 FAQ 的来源会话"
    },
    "reviewStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "approved",
      "description": "枚举值：pending(待审核) / approved(已通过) / rejected(已拒绝)；AI 生成 FAQ 需审核"
    },
    "vectorSynced": {
      "type": "boolean",
      "default": false,
      "description": "是否已同步到向量数据库"
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
