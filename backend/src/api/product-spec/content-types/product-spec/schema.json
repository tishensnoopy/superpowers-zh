{
  "kind": "collectionType",
  "collectionName": "product_specs",
  "info": {
    "singularName": "product-spec",
    "pluralName": "product-specs",
    "displayName": "Product Spec",
    "description": "Product specification/attribute for comparison",
    "icon": "Settings",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "规格名称（如 课时数 / 适合年龄 / 班型）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 50,
      "description": "规格代码（如 lesson_count / age_range），用于程序识别，唯一"
    },
    "unit": {
      "type": "string",
      "maxLength": 20,
      "description": "数值单位（如 课时 / 岁 / 人）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "text",
        "number",
        "select",
        "boolean"
      ],
      "default": "text",
      "description": "枚举值：text(文本) / number(数值) / select(下拉选择) / boolean(是否)"
    },
    "options": {
      "type": "string",
      "description": "下拉选项，逗号分隔（仅当 type=select 时使用，如 小班,中班,大班）",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "isVisible": {
      "type": "boolean",
      "default": true,
      "description": "是否在对比表中展示"
    },
    "position": {
      "type": "integer",
      "default": 0,
      "description": "在对比表中的排序，数值越小越靠前"
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
