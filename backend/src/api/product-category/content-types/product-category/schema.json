{
  "kind": "collectionType",
  "collectionName": "product_categories",
  "info": {
    "singularName": "product-category",
    "pluralName": "product-categories",
    "displayName": "Product Category",
    "description": "Product category for organizing products",
    "icon": "Folder",
    "draftAndPublish": false
  },
  "options": {
    "draftAndPublish": false,
    "singleton": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "分类名称",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100,
      "description": "分类 URL 路径（如 /courses/pinyin）"
    },
    "description": {
      "type": "text",
      "description": "分类描述",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "image": {
      "type": "media",
      "description": "分类图标/封面图，建议尺寸 400x400，支持 JPG/PNG/WebP",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "position": {
      "type": "integer",
      "default": 0,
      "description": "排序权重，数值越小越靠前"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "是否启用此分类"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "children",
      "description": "父级分类（用于构建层级分类树）"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-category.product-category",
      "mappedBy": "parent",
      "description": "子分类列表"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "categories",
      "description": "此分类下的产品列表"
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
