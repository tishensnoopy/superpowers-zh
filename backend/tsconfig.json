{
  "extends": "@strapi/typescript-utils/tsconfigs/server",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "config", "types"],
  "exclude": ["node_modules", "dist", "build", ".strapi", ".tmp", ".cache", "src/admin", "**/*.test.ts", "src/plugins/**", "types/generated/**"]
}
