# Central 生产环境变量配置示例
# 部署时复制为 .env 并替换所有 changeme / placeholder 值
# ============================================================
# 密钥生成命令（在服务器上执行后粘贴到下方对应字段）：
#   openssl rand -base64 32     # 适用于 JWT_SECRET / ADMIN_JWT_SECRET
#   openssl rand -hex 16        # 适用于 DATABASE_PASSWORD / INITIAL_ADMIN_PASSWORD
#   openssl rand -base64 32     # 适用于 AES_KEY（必须为 32 字节 base64）

# ------------------------------------------------------------
# PostgreSQL 数据库
# ------------------------------------------------------------
# 数据库密码（生产环境必须替换为强密码，建议 openssl rand -hex 16）
DATABASE_PASSWORD=changeme

# 数据库连接串（仅本地 dev 参考用，docker-compose.yml 会用 ${DATABASE_PASSWORD} 重新拼接）
# 生产容器内实际使用：postgres://central:${DATABASE_PASSWORD}@postgres:5432/control_db
DATABASE_URL=postgres://central:changeme@localhost:5432/control_db

# ------------------------------------------------------------
# Central 应用密钥
# ------------------------------------------------------------
# 主 JWT 签名密钥（32 字节随机串，openssl rand -base64 32）
JWT_SECRET=change-me-to-32-byte-random-string

# AES 加密密钥（32 字节 base64，openssl rand -base64 32）
AES_KEY=change-me-to-32-byte-base64-key

# Admin 子系统 JWT 签名密钥（与 JWT_SECRET 区分，openssl rand -base64 32）
ADMIN_JWT_SECRET=change-me-to-32-byte-random-string

# 初始管理员密码（首次 seed 时使用，建议 openssl rand -hex 16，部署后立即登录修改）
INITIAL_ADMIN_PASSWORD=change-me-initial-admin-password

# ------------------------------------------------------------
# Central 服务端口
# ------------------------------------------------------------
# 容器内 Next.js 监听端口（默认 3000，一般无需改动）
PORT=3000

# 宿主机映射端口（nginx overlay 启用后仅容器间可见，但仍需保留以供健康检查与直连调试）
CENTRAL_PORT=3000

# ------------------------------------------------------------
# 域名 + SSL
# ------------------------------------------------------------
# 部署域名（需与 Let's Encrypt 证书 CN 一致，nginx.conf 中 server_name 也要替换为同一值）
CENTRAL_DOMAIN=central.yousen.example.com

# ------------------------------------------------------------
# 备份策略
# ------------------------------------------------------------
# 数据库备份目录（宿主机绝对路径，cron 脚本会写入此目录）
# 注意：DEPLOY_PATH=/opt/central 时，central 代码在 /opt/central/central/，备份目录应在此之下
BACKUP_DIR=/opt/central/central/backups

# 备份保留天数（超过自动清理，建议 7-30）
BACKUP_RETENTION_DAYS=7
